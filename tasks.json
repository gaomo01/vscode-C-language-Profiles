{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Run Program",
            "command": "cmd",
            "args": [
                "/c",
                "e:\\WORKPLACE\\.vscode\\debug_wrapper.bat",
                "${file}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            }
        }
    ]
}